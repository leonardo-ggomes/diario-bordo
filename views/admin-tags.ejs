<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuração de Marcadores</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans min-h-screen p-6 md:p-12 text-slate-800 antialiased">
    <div class="max-w-3xl mx-auto">
        
        <div class="mb-6">
            <a href="/admin" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 hover:underline flex items-center gap-1">
                <span>←</span> Voltar para a Console
            </a>
        </div>

        <div class="mb-8">
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Marcadores Semanais</h1>
            <p class="text-sm text-slate-500 mt-1">Gerencie as tags pré-definidas que os usuários podem selecionar ao registrar o humor.</p>
        </div>

        <form action="/admin/tags" method="POST" class="bg-white p-6 rounded-3xl border border-slate-200/80 shadow-sm mb-8 flex flex-col md:flex-row gap-4 items-end">
            <div class="flex-1 w-full">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Novo Marcador</label>
                <input type="text" name="name" required placeholder="Ex: Carga Horária, Liderança, Ferramentas..." class="w-full bg-slate-50/50 border border-slate-200 p-3 rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition">
            </div>
            <button type="submit" class="w-full md:w-auto bg-slate-900 text-white font-bold px-6 py-3 rounded-xl hover:bg-slate-800 transition active:scale-[0.98] shadow-sm text-sm shrink-0">
                + Adicionar Tag
            </button>
        </form>

        <div class="bg-white rounded-3xl border border-slate-200/80 overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/30">
                <h3 class="font-bold text-slate-800 text-xs uppercase tracking-wider">Tags Ativas</h3>
            </div>
            
            <% if (tags.length > 0) { %>
                <ul class="divide-y divide-slate-100 text-sm">
                    <% tags.forEach(tag => { %>
                        <li class="flex items-center justify-between p-4 px-6 hover:bg-slate-50/50 transition">
                            <span class="inline-block bg-slate-100 text-slate-700 text-xs font-bold px-3 py-1.5 rounded-lg border border-slate-200/60">
                                <%= tag.name %>
                            </span>
                            
                            <form action="/admin/tags/delete/<%= tag.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja apagar a tag &quot;<%= tag.name %>&quot;?')" class="inline">
                                <button type="submit" class="text-rose-500 hover:text-rose-700 text-xs font-bold px-3 py-1.5 rounded-lg hover:bg-rose-50 transition">
                                    Remover
                                </button>
                            </form>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <div class="text-center py-10 text-slate-400">
                    <span class="text-3xl block mb-2 opacity-50">🏷️</span>
                    <p class="text-xs font-medium">Nenhuma tag cadastrada no momento.</p>
                </div>
            <% } %>
        </div>
        
    </div>
</body>
</html>