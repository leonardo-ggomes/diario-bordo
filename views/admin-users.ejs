<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerenciar Usuários Permitidos</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans min-h-screen p-6 md:p-12">
    <div class="max-w-4xl mx-auto">
        <div class="mb-6">
            <a href="/admin" class="text-sm font-semibold text-indigo-600 hover:underline">← Voltar para a Console</a>
        </div>

        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Usuários Autorizados</h1>
        <p class="text-sm text-slate-500 mt-1">Apenas as contas listadas abaixo conseguirão efetuar o login.</p>

        <form action="/admin/users" method="POST" class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm my-8 grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Nome</label>
                <input type="text" name="name" required placeholder="Nome do Aluno" class="w-full border p-2.5 rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">E-mail Único</label>
                <input type="email" name="email" required placeholder="aluno@empresa.com" class="w-full border p-2.5 rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Função</label>
                <select name="role" class="w-full border p-2.5 rounded-xl text-sm outline-none bg-white">
                    <option value="student">Aluno / Colaborador</option>
                    <option value="admin">Administrador</option>
                </select>
            </div>
            <button type="submit" class="bg-indigo-600 text-white font-semibold p-2.5 rounded-xl hover:bg-indigo-700 transition text-sm">
                Autorizar Usuário
            </button>
        </form>

        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 text-xs font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-3">Nome</th>
                        <th class="px-6 py-3">E-mail</th>
                        <th class="px-6 py-3">Nível</th>
                        <th class="px-6 py-3 text-right">Ação</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    <% users.forEach(user => { %>
                        <tr class="hover:bg-slate-50/50 transition">
                            <td class="px-6 py-4 font-semibold text-slate-900"><%= user.name %></td>
                            <td class="px-6 py-4 text-slate-500"><%= user.email %></td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 text-xs font-semibold rounded-md <%= user.role === 'admin' ? 'bg-purple-50 text-purple-700' : 'bg-slate-100 text-slate-700' %>">
                                    <%= user.role %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <form action="/admin/users/delete/<%= user.id %>" method="POST" onsubmit="return confirm('Revogar acesso deste usuário?')">
                                    <button class="text-red-500 hover:text-red-700 text-xs font-medium">Revogar</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>