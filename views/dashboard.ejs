<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Progresso</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Customização fina e minimalista da barra de scroll global */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(148, 163, 184, 0.2);
            border-radius: 99px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.4);
        }

        html, body {
            scrollbar-width: thin;
            scrollbar-color: rgba(148, 163, 184, 0.2) transparent;
        }

        /* Animação de entrada suave em cascata */
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-cascade {
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 min-h-screen font-sans antialiased flex justify-center items-start p-4 sm:p-6">

    <div class="w-full max-w-md mx-auto space-y-4">
        
        <% if (info === 'closed') { %>
            <div class="bg-amber-50/80 backdrop-blur-sm border border-amber-200/60 text-amber-800 p-4 rounded-2xl text-xs font-medium flex items-start gap-3 shadow-sm animate-cascade">
                <span class="text-base mt-0.5">🔒</span>
                <div>
                    <strong class="block font-bold mb-0.5">Janela de Coleta Encerrada</strong>
                    O formulário desta semana já foi fechado pelo gestor. Veja abaixo o seu histórico de registros.
                </div>
            </div>
        <% } %>

        <div class="bg-white p-6 sm:p-8 rounded-3xl shadow-xl shadow-slate-100/80 border border-slate-100 w-full animate-cascade" style="animation-delay: 0.05s;">
            
           <div class="flex justify-between items-start mb-6 pb-5 border-b border-slate-100">
    <div>
        <h1 class="text-xl font-black text-slate-900 tracking-tight">Meu Retrato</h1>
        <p class="text-xs text-slate-400 mt-0.5">Sua jornada nas últimas semanas</p>
    </div>
    
    <div class="flex flex-col items-end gap-2">
        <a href="/logout" class="text-[10px] font-bold text-slate-400 hover:text-rose-500 transition-colors flex items-center gap-1 bg-slate-50 px-2 py-1 rounded-md border border-slate-100">
            Sair <span>→</span>
        </a>
        
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 text-orange-600 px-3.5 py-1.5 rounded-2xl flex items-center gap-1.5 border border-orange-100/60 shadow-sm mt-1">
            <span class="text-sm animate-pulse">🔥</span>
            <span class="text-xs font-bold tracking-tight">
                <%= historico.length %> <%= historico.length === 1 ? 'Semana' : 'Semanas' %>
            </span>
        </div>
    </div>
</div>

            <div class="space-y-3.5 max-h-[380px] overflow-y-auto pr-1">
                <% if (historico.length > 0) { %>
                    <% historico.forEach((item, index) => { %>
                        <div class="flex items-center bg-slate-50/50 p-4 rounded-2xl border border-slate-100 hover:border-slate-200/80 hover:bg-slate-50 transition duration-200 animate-cascade" style="animation-delay: <%= 0.1 + (index * 0.05) %>s;">
                            
                            <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-2xl shadow-sm border border-slate-100/60 mr-4 shrink-0">
                                <%= getEmoji(item.sentiment_score) %>
                            </div>

                            <div class="flex-1 min-w-0">
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mb-1">
                                    <%= new Date(item.createdAt).toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' }) %>
                                </p>

                                <% if (item.tags) { %>
                                    <div class="flex flex-wrap gap-1 mt-1">
                                        <% item.tags.split(',').forEach(tag => { %>
                                            <span class="inline-block bg-white text-slate-600 text-[10px] font-semibold px-2 py-0.5 rounded-md border border-slate-200/60 shadow-2xs">
                                                <%= tag.trim() %>
                                            </span>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <p class="text-xs text-slate-300 italic">Sem marcadores registrados</p>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center text-slate-400 py-12 border border-dashed border-slate-200 rounded-2xl bg-slate-50/30">
                        <span class="text-3xl block mb-2 text-slate-300">🍃</span>
                        <p class="text-xs font-medium">Nenhum sentimento registrado ainda.</p>
                    </div>
                <% } %>
            </div>

            <div class="mt-6 pt-4 border-t border-slate-100">
                <% if (info === 'closed') { %>
                    <button disabled class="w-full text-center bg-slate-100 text-slate-400 font-semibold py-3.5 rounded-2xl text-xs cursor-not-allowed flex items-center justify-center gap-2">
                        🔒 Coleta Fechada
                    </button>
                <% } else { %>
                    <a href="/" class="block w-full text-center bg-slate-900 text-white font-semibold py-3.5 rounded-2xl text-xs hover:bg-slate-800 active:scale-[0.99] transition shadow-lg shadow-slate-900/5">
                        Registrar Novo Sentimento
                    </a>
                <% } %>
            </div>

        </div>
    </div>

</body>
</html>